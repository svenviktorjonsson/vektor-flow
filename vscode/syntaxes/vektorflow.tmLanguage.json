{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Vektor Flow",
  "scopeName": "source.vektorflow",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#line-print-sugar" },
    { "include": "#module-spill" },
    { "include": "#stdlib-member-call" },
    { "include": "#function-definition" },
    { "include": "#line-binding" },
    { "include": "#match-arm-bool" },
    { "include": "#match-wild" },
    { "include": "#keywords" },
    { "include": "#numbers" },
    { "include": "#operators-multi" },
    { "include": "#at-forms" },
    { "include": "#bracket-ops" },
    { "include": "#function-call" },
    { "include": "#punctuation" },
    { "include": "#operators-single" },
    { "include": "#type-names" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.vektorflow",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.vektorflow",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.vektorflow",
              "match": "\\\\(?:[\"\\\\nrt$]|.)"
            },
            {
              "comment": "Expr interpolation $( … ) : $ and ( are distinct from the inner expr",
              "contentName": "meta.embedded.expr.interpolation.vektorflow",
              "begin": "(?<!\\\\)(\\$)(\\()",
              "end": "(\\))",
              "beginCaptures": {
                "1": { "name": "punctuation.interpolation.dollar.vektorflow" },
                "2": { "name": "punctuation.interpolation.paren.start.vektorflow" }
              },
              "endCaptures": {
                "1": { "name": "punctuation.interpolation.paren.end.vektorflow" }
              },
              "patterns": [{ "include": "#interpolation-expr" }]
            },
            {
              "comment": "Simple $name and $a.b in strings — $ and path differ in color",
              "match": "(?<!\\\\)(\\$)([a-zA-Z_][a-zA-Z0-9_]*(?:\\.[a-zA-Z_][a-zA-Z0-9_]*)*(?:\\.\\d+[a-zA-Z]+)?)",
              "captures": {
                "1": { "name": "punctuation.interpolation.dollar.vektorflow" },
                "2": { "name": "variable.interpolation.name.vektorflow" }
              }
            }
          ]
        }
      ]
    },
    "line-print-sugar": {
      "patterns": [
        {
          "name": "keyword.operator.emit.line-sugar.vektorflow",
          "match": ":::"
        }
      ]
    },
    "module-spill": {
      "patterns": [
        {
          "comment": "Import spill : .math  : .io  (stdlib module name after the dot)",
          "match": "(:)(\\.)([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.module.spill.start.vektorflow" },
            "2": { "name": "keyword.module.spill.dot.vektorflow" },
            "3": { "name": "entity.name.module.std.vektorflow" }
          }
        }
      ]
    },
    "stdlib-member-call": {
      "patterns": [
        {
          "comment": "bridge.pop(  screen.frame(  — stdlib + method + (",
          "match": "\\b(bridge|io|math|time|screen|widget|collections|capture)\\b\\s*\\.\\s*([a-zA-Z_][a-zA-Z0-9_]*)\\s*(\\()",
          "captures": {
            "1": { "name": "entity.name.namespace.std.vektorflow" },
            "2": { "name": "entity.name.function.call.vektorflow" },
            "3": { "name": "punctuation.parens.begin.vektorflow" }
          }
        }
      ]
    },
    "function-definition": {
      "patterns": [
        {
          "comment": "f(num x):  f(x:num):  f(num x, int y) -> num: — head line",
          "match": "^\\s*([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(([^\\)]*)\\)\\s*(?:(->)\\s*([^:]+))?\\s*(:)(?:\\s*(?:#.*)?\\s*)?$",
          "captures": {
            "1": { "name": "entity.name.function.definition.vektorflow" },
            "2": { "name": "variable.parameter.list.vektorflow" },
            "3": { "name": "keyword.operator.thinarrow.vektorflow" },
            "4": { "name": "meta.function.return-type.vektorflow" },
            "5": { "name": "punctuation.block.head.vektorflow" }
          }
        }
      ]
    },
    "line-binding": {
      "patterns": [
        {
          "comment": "a: 3  (not a::, not f(x):) — simple toplevel/line binding",
          "match": "^\\s*([a-zA-Z_][a-zA-Z0-9_]*)\\s*:(?!:)(?!:)",
          "captures": {
            "1": { "name": "variable.name.binding.vektorflow" }
          }
        }
      ]
    },
    "match-arm-bool": {
      "patterns": [
        {
          "name": "constant.language.match-arm.boolean.vektorflow",
          "match": "\\b(true|false)\\?"
        }
      ]
    },
    "match-wild": {
      "patterns": [
        {
          "name": "keyword.wildcard.match.vektorflow",
          "match": "\\b_\\?"
        }
      ]
    },
    "interpolation-expr": {
      "patterns": [
        { "include": "#comments" },
        { "include": "#numbers" },
        { "include": "#operators-multi" },
        { "include": "#at-forms" },
        { "include": "#function-call" },
        { "include": "#punctuation" },
        { "include": "#operators-single" },
        { "include": "#identifiers" }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "constant.language.boolean.vektorflow",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "storage.type.primitive.vektorflow",
          "match": "\\b(int|float|num|str|byte|bytes|bool|any)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.vektorflow",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.vektorflow",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "operators-multi": {
      "patterns": [
        {
          "name": "keyword.operator.emit.vektorflow",
          "match": "::"
        },
        {
          "name": "keyword.operator.pipe.vektorflow",
          "match": ">>"
        },
        {
          "name": "keyword.operator.comparison.vektorflow",
          "match": "==|~=|!=|<=|>="
        },
        {
          "name": "keyword.operator.fatarrow.vektorflow",
          "match": "=>"
        },
        {
          "name": "keyword.operator.thinarrow.vektorflow",
          "match": "->"
        },
        {
          "name": "keyword.operator.range.vektorflow",
          "match": "\\.\\."
        },
        {
          "name": "keyword.operator.xor.vektorflow",
          "match": "><"
        },
        {
          "name": "keyword.operator.bool.and.vektorflow",
          "match": "/\\\\"
        },
        {
          "name": "keyword.operator.bool.or.vektorflow",
          "match": "\\\\/"
        }
      ]
    },
    "at-forms": {
      "patterns": [
        {
          "name": "keyword.control.at.emit.vektorflow",
          "match": "@::"
        },
        {
          "name": "keyword.control.at.return.vektorflow",
          "match": "@:"
        },
        {
          "name": "keyword.control.at.continue.vektorflow",
          "match": "@>"
        },
        {
          "name": "keyword.control.at.break.vektorflow",
          "match": "@\\|"
        },
        {
          "name": "keyword.control.at.exit.vektorflow",
          "match": "@!"
        }
      ]
    },
    "bracket-ops": {
      "patterns": [
        {
          "name": "keyword.operator.infix.vektorflow",
          "match": "\\(\\s*[+\\-*/]\\s*\\)"
        },
        {
          "name": "keyword.operator.infix.vektorflow",
          "match": "\\{\\s*[+\\-*/]\\s*\\}"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.terminator.statement.vektorflow",
          "match": ";"
        },
        {
          "name": "punctuation.separator.comma.vektorflow",
          "match": ","
        },
        {
          "name": "punctuation.parens.begin.vektorflow",
          "match": "\\("
        },
        {
          "name": "punctuation.parens.end.vektorflow",
          "match": "\\)"
        },
        {
          "name": "punctuation.brackets.begin.vektorflow",
          "match": "\\["
        },
        {
          "name": "punctuation.brackets.end.vektorflow",
          "match": "\\]"
        },
        {
          "name": "punctuation.braces.begin.vektorflow",
          "match": "\\{"
        },
        {
          "name": "punctuation.braces.end.vektorflow",
          "match": "\\}"
        },
        {
          "name": "keyword.operator.abs.vektorflow",
          "match": "\\|"
        },
        {
          "name": "keyword.operator.match.vektorflow",
          "match": "\\?"
        }
      ]
    },
    "operators-single": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.vektorflow",
          "match": "="
        },
        {
          "name": "keyword.operator.relational.punctuation.vektorflow",
          "match": "[<>]"
        },
        {
          "name": "keyword.operator.arithmetic.vektorflow",
          "match": "[+\\-*/^%]"
        },
        {
          "name": "keyword.operator.concat.vektorflow",
          "match": "&"
        },
        {
          "name": "keyword.operator.lognot.vektorflow",
          "match": "~"
        },
        {
          "name": "keyword.operator.lambda.vektorflow",
          "match": "\\$"
        },
        {
          "name": "keyword.operator.kwargbind.vektorflow",
          "match": ":"
        },
        {
          "name": "keyword.operator.deref.vektorflow",
          "match": "\\."
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "comment": "identifier( — calls (def line handled above; std method handled above)",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(\\()",
          "captures": {
            "1": { "name": "entity.name.function.call.vektorflow" },
            "2": { "name": "punctuation.parens.begin.vektorflow" }
          }
        }
      ]
    },
    "type-names": {
      "patterns": [
        {
          "name": "entity.name.type.class.vektorflow",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.vektorflow",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
