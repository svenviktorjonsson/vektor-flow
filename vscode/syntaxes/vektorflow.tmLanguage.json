{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Vektor Flow",
  "scopeName": "source.vektorflow",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#imports" },
    { "include": "#function-definition" },
    { "include": "#type-definition" },
    { "include": "#shape-type-expressions" },
    { "include": "#typed-bindings" },
    { "include": "#constant-binding" },
    { "include": "#dotted-binding" },
    { "include": "#line-binding" },
    { "include": "#control-heads" },
    { "include": "#type-switch-arms" },
    { "include": "#match-arm-bool" },
    { "include": "#match-wild" },
    { "include": "#qualified-constants" },
    { "include": "#stdlib-member-call" },
    { "include": "#member-call" },
    { "include": "#field-access" },
    { "include": "#postfix-typeof" },
    { "include": "#format-suffix" },
    { "include": "#lambda-head" },
    { "include": "#function-call" },
    { "include": "#property-labels" },
    { "include": "#multiset-counts" },
    { "include": "#keywords" },
    { "include": "#numbers" },
    { "include": "#operators-multi" },
    { "include": "#at-forms" },
    { "include": "#bracket-ops" },
    { "include": "#punctuation" },
    { "include": "#operators-single" },
    { "include": "#type-names" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.vektorflow",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.vektorflow",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.vektorflow",
              "match": "\\\\(?:[\"\\\\nrt$]|.)"
            },
            {
              "contentName": "meta.embedded.expr.interpolation.vektorflow",
              "begin": "(?<!\\\\)(\\$)(\\()",
              "end": "(\\))",
              "beginCaptures": {
                "1": { "name": "punctuation.interpolation.dollar.vektorflow" },
                "2": { "name": "punctuation.interpolation.paren.start.vektorflow" }
              },
              "endCaptures": {
                "1": { "name": "punctuation.interpolation.paren.end.vektorflow" }
              },
              "patterns": [
                { "include": "#interpolation-expr" }
              ]
            },
            {
              "match": "(?<!\\\\)(\\$)([a-zA-Z_][a-zA-Z0-9_]*(?:\\.[a-zA-Z_][a-zA-Z0-9_]*)*(?:\\.\\d+[a-zA-Z]+)?)",
              "captures": {
                "1": { "name": "punctuation.interpolation.dollar.vektorflow" },
                "2": { "name": "variable.interpolation.name.vektorflow" }
              }
            }
          ]
        },
        {
          "name": "string.quoted.single.raw.vektorflow",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.raw.vektorflow",
              "match": "\\\\['\\\\]"
            }
          ]
        }
      ]
    },
    "imports": {
      "patterns": [
        {
          "comment": ":.math or : .math",
          "match": "^(\\s*)(:)(\\s*)(\\.)([a-zA-Z_][a-zA-Z0-9_]*)\\b",
          "captures": {
            "2": { "name": "keyword.module.spill.start.vektorflow" },
            "4": { "name": "keyword.module.spill.dot.vektorflow" },
            "5": { "name": "entity.name.namespace.vektorflow" }
          }
        },
        {
          "comment": "math: .math or ui:.ui",
          "match": "^(\\s*)([a-zA-Z_][a-zA-Z0-9_]*)(\\s*:)(\\s*)(\\.)([a-zA-Z_][a-zA-Z0-9_]*)\\b",
          "captures": {
            "2": { "name": "variable.other.assignment.vektorflow" },
            "3": { "name": "punctuation.separator.key-value.vektorflow" },
            "5": { "name": "keyword.module.spill.dot.vektorflow" },
            "6": { "name": "entity.name.namespace.vektorflow" }
          }
        }
      ]
    },
    "function-definition": {
      "patterns": [
        {
          "comment": "function head with optional return type",
          "match": "^(\\s*)([a-zA-Z_][a-zA-Z0-9_]*|/\\\\|\\\\/|><|<=|>=|!=|[+\\-*/%^&~=<>])(\\s*)(\\()([^)]*)(\\))(\\s*(->)\\s*([^:#\\n]+))?(\\s*)(:)(?:\\s*(?:#.*)?\\s*)?$",
          "captures": {
            "2": { "name": "entity.name.function.definition.vektorflow" },
            "4": { "name": "punctuation.parens.begin.vektorflow" },
            "5": { "name": "variable.parameter.vektorflow" },
            "6": { "name": "punctuation.parens.end.vektorflow" },
            "9": { "name": "keyword.operator.thinarrow.vektorflow" },
            "10": { "name": "entity.name.type.vektorflow" },
            "12": { "name": "punctuation.block.head.vektorflow" }
          }
        }
      ]
    },
    "type-definition": {
      "patterns": [
        {
          "comment": "Point : (x:num, y:num) or Alias : [num:2]",
          "match": "^(\\s*)([A-Z][a-zA-Z0-9_]*)(\\s*:)(\\s*)(?=(?:\\(|\\[|\\{|int\\b|num\\b|str\\b|byte\\b|bytes\\b|bool\\b|any\\b|[A-Z][a-zA-Z0-9_]*\\b))",
          "captures": {
            "2": { "name": "entity.name.type.definition.vektorflow" },
            "3": { "name": "punctuation.separator.type.vektorflow" }
          }
        }
      ]
    },
    "shape-type-expressions": {
      "patterns": [
        {
          "comment": "shape/type expressions like [num:n] or [Point:n+m]",
          "begin": "(?=\\[\\s*(?:int|num|str|byte|bytes|bool|any|vec|list|set|map|[A-Z][a-zA-Z0-9_]*)\\s*:)(\\[)",
          "beginCaptures": {
            "1": { "name": "punctuation.brackets.begin.vektorflow" }
          },
          "end": "(\\])",
          "endCaptures": {
            "1": { "name": "punctuation.brackets.end.vektorflow" }
          },
          "patterns": [
            { "include": "#type-names" },
            {
              "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b",
              "name": "variable.parameter.size.vektorflow"
            },
            { "include": "#numbers" },
            { "include": "#operators-multi" },
            { "include": "#operators-single" },
            { "include": "#punctuation" }
          ]
        }
      ]
    },
    "typed-bindings": {
      "patterns": [
        {
          "comment": "[num:2] xs: ... or Point p: ...",
          "match": "^(\\s*)((?:\\[[^\\]\\n]+\\]|\\{[^}\\n]+\\}|\\([^\\)\\n]+\\)|[A-Z][a-zA-Z0-9_]*|int|num|str|byte|bytes|bool|any))(\\s+)([a-zA-Z_][a-zA-Z0-9_]*)(\\s*:)(?!:)",
          "captures": {
            "2": { "name": "entity.name.type.vektorflow" },
            "4": { "name": "variable.other.assignment.vektorflow" },
            "5": { "name": "punctuation.separator.key-value.vektorflow" }
          }
        },
        {
          "comment": "field type annotations x:num inside records, params, and switch-like heads",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(\\s*:)(\\s*)((?:\\[[^\\]\\n]+\\]|\\{[^}\\n]+\\}|\\([^\\)\\n]+\\)|[A-Z][a-zA-Z0-9_]*|int|num|str|byte|bytes|bool|any))",
          "captures": {
            "1": { "name": "variable.parameter.vektorflow" },
            "2": { "name": "punctuation.separator.type.vektorflow" },
            "4": { "name": "entity.name.type.vektorflow" }
          }
        }
      ]
    },
    "constant-binding": {
      "patterns": [
        {
          "match": "^(\\s*)([A-Z][A-Z0-9_]*)(\\s*:)(?!:)",
          "captures": {
            "2": { "name": "variable.other.constant.vektorflow" },
            "3": { "name": "punctuation.separator.key-value.vektorflow" }
          }
        }
      ]
    },
    "dotted-binding": {
      "patterns": [
        {
          "comment": "person.name: ... or moved.state.total: ...",
          "match": "^(\\s*)([a-zA-Z_][a-zA-Z0-9_]*)(\\s*\\.\\s*)([a-zA-Z_][a-zA-Z0-9_]*)(\\s*:)(?!:)",
          "captures": {
            "2": { "name": "variable.other.vektorflow" },
            "3": { "name": "keyword.operator.deref.vektorflow" },
            "4": { "name": "entity.name.tag.vektorflow" },
            "5": { "name": "punctuation.separator.key-value.vektorflow" }
          }
        }
      ]
    },
    "line-binding": {
      "patterns": [
        {
          "match": "^(\\s*)([a-z_][a-zA-Z0-9_]*)(\\s*:)(?!:)",
          "captures": {
            "2": { "name": "variable.other.assignment.vektorflow" },
            "3": { "name": "punctuation.separator.key-value.vektorflow" }
          }
        }
      ]
    },
    "control-heads": {
      "patterns": [
        {
          "comment": "line-oriented heads with an explicit relational operator, e.g. k<4? or n<=3?>",
          "match": "^(\\s*)([^#\\n]*?)(!=|<=|>=|=|<|>)([^#\\n]*?)(\\?\\?>|\\?>|\\?\\?|!\\?)(?=\\s|$)",
          "captures": {
            "2": { "name": "variable.other.readwrite.vektorflow" },
            "3": { "name": "keyword.operator.comparison.vektorflow" },
            "4": { "name": "variable.other.readwrite.vektorflow" },
            "5": { "name": "keyword.control.conditional.vektorflow" }
          }
        },
        {
          "comment": "generic line-oriented conditional/switch/catch heads like value?? or missing!?",
          "match": "^(\\s*)([^#\\n][^\\n]*?)(\\?\\?>|\\?>|\\?\\?|!\\?)(?=\\s|$)",
          "captures": {
            "2": { "name": "variable.other.readwrite.vektorflow" },
            "3": { "name": "keyword.control.conditional.vektorflow" }
          }
        }
      ]
    },
    "type-switch-arms": {
      "patterns": [
        {
          "match": "\\b(int|num|str|byte|bytes|bool|any|[A-Z][a-zA-Z0-9_]*)(\\s*)(=>)",
          "captures": {
            "1": { "name": "entity.name.type.vektorflow" },
            "3": { "name": "keyword.operator.fatarrow.vektorflow" }
          }
        }
      ]
    },
    "match-arm-bool": {
      "patterns": [
        {
          "name": "constant.language.match-arm.boolean.vektorflow",
          "match": "\\b(true|false)\\?"
        }
      ]
    },
    "match-wild": {
      "patterns": [
        {
          "name": "keyword.wildcard.match.vektorflow",
          "match": "\\b_\\?"
        }
      ]
    },
    "qualified-constants": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(\\s*\\.\\s*)([A-Z][A-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "entity.name.namespace.vektorflow" },
            "2": { "name": "punctuation.accessor.vektorflow" },
            "3": { "name": "variable.other.constant.vektorflow" }
          }
        }
      ]
    },
    "stdlib-member-call": {
      "patterns": [
        {
          "match": "\\b(bridge|capture|collections|errors|io|math|screen|stat|time|ui|widget)\\b(\\s*\\.\\s*)([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*\\()",
          "captures": {
            "1": { "name": "entity.name.namespace.vektorflow" },
            "2": { "name": "punctuation.accessor.vektorflow" },
            "3": { "name": "support.function.vektorflow" }
          }
        },
        {
          "match": "\\b(bridge|capture|collections|errors|io|math|screen|stat|time|ui|widget)\\b(\\s*\\.\\s*)([a-zA-Z_][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": { "name": "entity.name.namespace.vektorflow" },
            "2": { "name": "punctuation.accessor.vektorflow" },
            "3": { "name": "variable.other.member.vektorflow" }
          }
        }
      ]
    },
    "member-call": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(\\s*\\.\\s*)([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*\\()",
          "captures": {
            "1": { "name": "variable.other.readwrite.vektorflow" },
            "2": { "name": "punctuation.accessor.vektorflow" },
            "3": { "name": "entity.name.function.member.vektorflow" }
          }
        }
      ]
    },
    "field-access": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(\\s*\\.\\s*)([a-zA-Z_][a-zA-Z0-9_]*)(?!\\s*\\()",
          "captures": {
            "1": { "name": "variable.other.readwrite.vektorflow" },
            "2": { "name": "punctuation.accessor.vektorflow" },
            "3": { "name": "variable.other.member.vektorflow" }
          }
        }
      ]
    },
    "postfix-typeof": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(\\s*\\.)(?=\\s*(?:$|[),;\\]}}#]))",
          "captures": {
            "1": { "name": "variable.other.readwrite.vektorflow" },
            "2": { "name": "keyword.operator.typeof.vektorflow" }
          }
        }
      ]
    },
    "format-suffix": {
      "patterns": [
        {
          "match": "(\\.)(\\d+)([a-zA-Z]+)\\b",
          "captures": {
            "1": { "name": "keyword.operator.format.vektorflow" },
            "2": { "name": "constant.numeric.format.precision.vektorflow" },
            "3": { "name": "storage.modifier.format.vektorflow" }
          }
        }
      ]
    },
    "lambda-head": {
      "patterns": [
        {
          "match": "(\\$)(\\()([^)]*)(\\))(\\s*:)",
          "captures": {
            "1": { "name": "keyword.operator.lambda.vektorflow" },
            "2": { "name": "punctuation.parens.begin.vektorflow" },
            "3": { "name": "variable.parameter.vektorflow" },
            "4": { "name": "punctuation.parens.end.vektorflow" },
            "5": { "name": "punctuation.block.head.vektorflow" }
          }
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*\\()",
          "captures": {
            "1": { "name": "entity.name.function.call.vektorflow" }
          }
        }
      ]
    },
    "property-labels": {
      "patterns": [
        {
          "match": "([({\\[,]\\s*)([a-zA-Z_][a-zA-Z0-9_]*)(\\s*:)(?!:)",
          "captures": {
            "2": { "name": "entity.name.tag.vektorflow" },
            "3": { "name": "punctuation.separator.key-value.vektorflow" }
          }
        }
      ]
    },
    "multiset-counts": {
      "patterns": [
        {
          "comment": "numeric multiset/map counts like {1:1, 2:1}",
          "match": "([\\{,]\\s*)(\\d+)(\\s*:)(\\s*)(\\d+)(?=\\s*(?:,|\\}))",
          "captures": {
            "2": { "name": "constant.numeric.integer.vektorflow" },
            "3": { "name": "punctuation.separator.key-value.vektorflow" },
            "5": { "name": "constant.numeric.multiset.count.vektorflow" }
          }
        }
      ]
    },
    "interpolation-expr": {
      "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#qualified-constants" },
        { "include": "#stdlib-member-call" },
        { "include": "#member-call" },
        { "include": "#postfix-typeof" },
        { "include": "#function-call" },
        { "include": "#property-labels" },
        { "include": "#numbers" },
        { "include": "#operators-multi" },
        { "include": "#at-forms" },
        { "include": "#interpolation-nested-parens" },
        { "include": "#punctuation" },
        { "include": "#operators-single" },
        { "include": "#type-names" },
        { "include": "#identifiers" }
      ]
    },
    "interpolation-nested-parens": {
      "patterns": [
        {
          "name": "meta.group.parens.interpolation.vektorflow",
          "begin": "\\(",
          "end": "\\)",
          "beginCaptures": {
            "0": { "name": "punctuation.parens.begin.vektorflow" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.parens.end.vektorflow" }
          },
          "patterns": [
            { "include": "#interpolation-expr" }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "constant.language.boolean.vektorflow",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.vektorflow",
          "match": "\\bnull\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.vektorflow",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.vektorflow",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "operators-multi": {
      "patterns": [
        {
          "name": "keyword.operator.emit.line-sugar.vektorflow",
          "match": ":::"
        },
        {
          "name": "keyword.operator.emit.vektorflow",
          "match": "::"
        },
        {
          "name": "keyword.operator.pipe.vektorflow",
          "match": ">>"
        },
        {
          "name": "keyword.operator.comparison.vektorflow",
          "match": "!=|<=|>="
        },
        {
          "name": "keyword.operator.fatarrow.vektorflow",
          "match": "=>"
        },
        {
          "name": "keyword.operator.thinarrow.vektorflow",
          "match": "->"
        },
        {
          "name": "keyword.operator.range.vektorflow",
          "match": "\\.\\."
        },
        {
          "name": "keyword.control.loop.vektorflow",
          "match": "\\?\\?>|\\?>"
        },
        {
          "name": "keyword.control.switch.vektorflow",
          "match": "\\?\\?"
        },
        {
          "name": "keyword.operator.xor.vektorflow",
          "match": "><"
        },
        {
          "name": "keyword.operator.bool.and.vektorflow",
          "match": "/\\\\"
        },
        {
          "name": "keyword.operator.bool.or.vektorflow",
          "match": "\\\\/"
        }
      ]
    },
    "at-forms": {
      "patterns": [
        {
          "name": "keyword.control.at.emit.vektorflow",
          "match": "@::"
        },
        {
          "name": "keyword.control.at.return.vektorflow",
          "match": "@:"
        },
        {
          "name": "keyword.control.at.continue.vektorflow",
          "match": "@>"
        },
        {
          "name": "keyword.control.at.break.vektorflow",
          "match": "@\\|"
        },
        {
          "name": "keyword.control.at.exit.vektorflow",
          "match": "@!"
        }
      ]
    },
    "bracket-ops": {
      "patterns": [
        {
          "name": "keyword.operator.infix.vektorflow",
          "match": "\\(\\s*(?:[+\\-*/%^&~]|/\\\\|\\\\/|><|<=|>=|!=|=|<|>)\\s*\\)"
        },
        {
          "name": "keyword.operator.infix.vektorflow",
          "match": "\\{\\s*(?:[+\\-*/%^&~]|/\\\\|\\\\/|><|<=|>=|!=|=|<|>)\\s*\\}"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.terminator.statement.vektorflow",
          "match": ";"
        },
        {
          "name": "punctuation.separator.comma.vektorflow",
          "match": ","
        },
        {
          "name": "punctuation.parens.begin.vektorflow",
          "match": "\\("
        },
        {
          "name": "punctuation.parens.end.vektorflow",
          "match": "\\)"
        },
        {
          "name": "punctuation.brackets.begin.vektorflow",
          "match": "\\["
        },
        {
          "name": "punctuation.brackets.end.vektorflow",
          "match": "\\]"
        },
        {
          "name": "punctuation.braces.begin.vektorflow",
          "match": "\\{"
        },
        {
          "name": "punctuation.braces.end.vektorflow",
          "match": "\\}"
        },
        {
          "name": "keyword.operator.abs.vektorflow",
          "match": "\\|"
        },
        {
          "name": "keyword.control.conditional.vektorflow",
          "match": "\\?"
        }
      ]
    },
    "operators-single": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.vektorflow",
          "match": "="
        },
        {
          "name": "keyword.operator.relational.punctuation.vektorflow",
          "match": "[<>]"
        },
        {
          "name": "keyword.operator.arithmetic.vektorflow",
          "match": "[+\\-*/^%]"
        },
        {
          "name": "keyword.operator.concat.vektorflow",
          "match": "&"
        },
        {
          "name": "keyword.operator.lognot.vektorflow",
          "match": "~"
        },
        {
          "name": "keyword.operator.lambda.vektorflow",
          "match": "\\$"
        },
        {
          "name": "keyword.operator.kwargbind.vektorflow",
          "match": ":"
        },
        {
          "name": "keyword.operator.deref.vektorflow",
          "match": "\\."
        }
      ]
    },
    "type-names": {
      "patterns": [
        {
          "name": "entity.name.type.builtin.vektorflow",
          "match": "\\b(int|num|str|byte|bytes|bool|any|vec|list|set|map)\\b"
        },
        {
          "name": "entity.name.type.class.vektorflow",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.vektorflow",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
