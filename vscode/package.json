{
  "name": "vektorflow",
  "displayName": "Vektor Flow",
  "description": "Syntax highlighting and run support for Vektor Flow (.vkf) files",
  "version": "0.0.7",
  "publisher": "vektorflow",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/svenviktorjonsson/vektor-flow.git"
  },
  "homepage": "https://github.com/svenviktorjonsson/vektor-flow",
  "bugs": {
    "url": "https://github.com/svenviktorjonsson/vektor-flow/issues"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Programming Languages"],
  "keywords": ["vektorflow", "vkf", "math"],
  "main": "./extension.js",
  "files": [
    "LICENSE",
    "README.md",
    "extension.js",
    "language-configuration.json",
    "syntaxes/**",
    "themes/**"
  ],
  "activationEvents": [
    "onLanguage:vektorflow",
    "onCommand:vektorflow.checkFile",
    "onCommand:vektorflow.showOutput",
    "onCommand:vektorflow.runFile",
    "onCommand:vektorflow.parseFile",
    "onCommand:vektorflow.buildFile"
  ],
  "contributes": {
    "languages": [
      {
        "id": "vektorflow",
        "aliases": ["Vektor Flow", "vkf"],
        "extensions": [".vkf"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "vektorflow",
        "scopeName": "source.vektorflow",
        "path": "./syntaxes/vektorflow.tmLanguage.json"
      }
    ],
    "themes": [
      {
        "label": "Vektor Flow Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/vektorflow-dark-color-theme.json"
      },
      {
        "label": "Vektor Flow Light",
        "uiTheme": "vs",
        "path": "./themes/vektorflow-light-color-theme.json"
      }
    ],
    "commands": [
      {
        "command": "vektorflow.runFile",
        "title": "Run Vektor Flow File",
        "icon": "$(play)"
      },
      {
        "command": "vektorflow.checkFile",
        "title": "Check Vektor Flow File",
        "icon": "$(check)"
      },
      {
        "command": "vektorflow.showOutput",
        "title": "Show Vektor Flow Output",
        "icon": "$(output)"
      },
      {
        "command": "vektorflow.parseFile",
        "title": "Parse Vektor Flow File",
        "icon": "$(search)"
      },
      {
        "command": "vektorflow.buildFile",
        "title": "Build Vektor Flow File",
        "icon": "$(gear)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "vektorflow.parseFile",
          "when": "editorLangId == vektorflow",
          "group": "navigation@1"
        },
        {
          "command": "vektorflow.checkFile",
          "when": "editorLangId == vektorflow",
          "group": "navigation@2"
        },
        {
          "command": "vektorflow.runFile",
          "when": "editorLangId == vektorflow",
          "group": "navigation@3"
        },
        {
          "command": "vektorflow.buildFile",
          "when": "editorLangId == vektorflow",
          "group": "navigation@4"
        }
      ],
      "commandPalette": [
        {
          "command": "vektorflow.parseFile"
        },
        {
          "command": "vektorflow.checkFile"
        },
        {
          "command": "vektorflow.runFile"
        },
        {
          "command": "vektorflow.buildFile"
        },
        {
          "command": "vektorflow.showOutput"
        }
      ]
    },
    "configuration": {
      "title": "Vektor Flow",
      "properties": {
        "vektorflow.compilerPath": {
          "type": "string",
          "default": "vkf",
          "description": "Executable used for Vektor Flow commands. Leave set to vkf when the compiler is on PATH, or point it to a specific binary."
        },
        "vektorflow.compilerArgs": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Extra arguments inserted before the Vektor Flow subcommand."
        },
        "vektorflow.pythonPath": {
          "type": "string",
          "default": "python",
          "description": "Legacy fallback used only when vektorflow.compilerPath is blank. It runs python -m vektorflow.cli."
        },
        "vektorflow.useNativeCoreCommands": {
          "type": "boolean",
          "default": true,
          "description": "Use native-core compiler subcommands for build flows. Parse always uses parse-native-core in this MVP."
        },
        "vektorflow.enableDiagnostics": {
          "type": "boolean",
          "default": true,
          "description": "Run compiler-backed Vektor Flow diagnostics for .vkf files and surface location-bearing parse/check errors in the editor."
        },
        "vektorflow.diagnosticsDebounceMs": {
          "type": "number",
          "default": 350,
          "minimum": 0,
          "description": "Delay before rerunning Vektor Flow diagnostics after edits."
        }
      }
    },
    "configurationDefaults": {
      "files.associations": {
        "*.vkf": "vektorflow"
      }
    }
  },
  "scripts": {}
}
