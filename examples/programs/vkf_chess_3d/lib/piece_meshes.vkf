piece_vertices(side:num, role:num) -> list(num):
    """Return side-colored baked vertices for a chess role."""
    side = Side.white?
        role = PieceRole.pawn? @: white_pawn_vertices()
        role = PieceRole.rook? @: white_rook_vertices()
        role = PieceRole.knight? @: white_knight_vertices()
        role = PieceRole.bishop? @: white_bishop_vertices()
        role = PieceRole.queen? @: white_queen_vertices()
        role = PieceRole.king? @: white_king_vertices()
    side = Side.black?
        role = PieceRole.pawn? @: black_pawn_vertices()
        role = PieceRole.rook? @: black_rook_vertices()
        role = PieceRole.knight? @: black_knight_vertices()
        role = PieceRole.bishop? @: black_bishop_vertices()
        role = PieceRole.queen? @: black_queen_vertices()
        role = PieceRole.king? @: black_king_vertices()
    @: white_pawn_vertices()

piece_indices(role:num) -> list(num):
    """Return indexed triangles for a chess role."""
    role = PieceRole.pawn? @: pawn_indices()
    role = PieceRole.rook? @: rook_indices()
    role = PieceRole.knight? @: knight_indices()
    role = PieceRole.bishop? @: bishop_indices()
    role = PieceRole.queen? @: queen_indices()
    role = PieceRole.king? @: king_indices()
    @: pawn_indices()
