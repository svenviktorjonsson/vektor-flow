ui:.ui
ui.set_mode("overlay")

d: ui.display
f: d.Frame()
d.add_frame(f, (0.08, 0.10, 0.62, 0.72))

axis: ui.axis_3d(
  f,
  x_min: -2,
  x_max: 2,
  y_min: -2,
  y_max: 2,
  z_min: -2,
  z_max: 2,
  prefix: "crosshair3d"
)

cam: f.add_camera(
  pos: [4.0, 4.0, 5.657],
  target: [0, 0, 0],
  up: [0, 0, 1],
  fov: 42,
  projection: "orthographic",
  ortho_scale: 3.2
)

axis.crosshair(
  width: 1,
  tick_len: 0.04
)
