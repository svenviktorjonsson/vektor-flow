# Static light setup for visible shading.
cam: scene.add_camera(pos:[2.8, 1.9, 2.6], target:[0,0,0], up:[0,0,1], fov:45)
light: scene.add_light(pos:[1.7, -1.2, 3.0], model:"blinn_phong", color:"white")

# Drive the time-indexed field with a tiny render loop.
# t_idx is clamped/checked internally by set_t.

t_idx: 0

true?
    surface.set_t(t_idx)
    t_idx: t_idx + 1
    t_idx >= surface.t_count?
        t_idx: 0
    t.sleep(0.032)
