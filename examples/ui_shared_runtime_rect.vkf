root_c_vertex_hidden_edge_hidden: root_c_vertex_hidden.add(
  x: [0.16, 0.66, 0.6, 0.22],
  y: [0.04, 0.1, 0.48, 0.54],
  face_color: [0.22, 0.54, 0.96, 0.46],
  edge_color: [0.12, 0.95, 0.95, 0],
  vertex_color: [1, 0.82, 0.2, 1],
  origin: [0.41, 0.29, 0],
