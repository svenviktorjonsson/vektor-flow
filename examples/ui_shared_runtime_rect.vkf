root_b_edge_hidden_x: [-0.58, 0.58, 0.5, -0.5]
root_b_edge_hidden_y: [-0.52, -0.42, 0.48, 0.56]
root_b_edge_hidden_x_uv: [[root_b_edge_hidden_x.0, root_b_edge_hidden_x.3], [root_b_edge_hidden_x.1, root_b_edge_hidden_x.2]]
root_b_edge_hidden_y_uv: [[root_b_edge_hidden_y.0, root_b_edge_hidden_y.3], [root_b_edge_hidden_y.1, root_b_edge_hidden_y.2]]
root_b_edge_hidden: root_b.add(
  x_uv: root_b_edge_hidden_x_uv,
  y_uv: root_b_edge_hidden_y_uv,
  z: 0,
  face_color: [0.16, 0.74, 0.34, 0.46],
  edge_color: [0.2, 1, 0.7, 0],
  vertex_color: [1, 0.25, 0.78, 1],
  vertex_size: 4,
  edge_width: 2
)

root_b_edge_hidden_face_hidden_x: [-0.72, -0.24, -0.3, -0.66]
root_b_edge_hidden_face_hidden_y: [-0.56, -0.5, -0.12, -0.06]
root_b_edge_hidden_face_hidden_x_uv: [[root_b_edge_hidden_face_hidden_x.0, root_b_edge_hidden_face_hidden_x.3], [root_b_edge_hidden_face_hidden_x.1, root_b_edge_hidden_face_hidden_x.2]]
root_b_edge_hidden_face_hidden_y_uv: [[root_b_edge_hidden_face_hidden_y.0, root_b_edge_hidden_face_hidden_y.3], [root_b_edge_hidden_face_hidden_y.1, root_b_edge_hidden_face_hidden_y.2]]
root_b_edge_hidden_face_hidden: root_b_edge_hidden.add(
  x_uv: root_b_edge_hidden_face_hidden_x_uv,
  y_uv: root_b_edge_hidden_face_hidden_y_uv,
  z: 0,
  face_color: [0.16, 0.74, 0.34, 0],
  edge_color: [0.2, 1, 0.7, 1],
  vertex_color: [1, 0.25, 0.78, 1],
  vertex_size: 4,
  edge_width: 2
)

root_b_edge_hidden_vertex_hidden_x: [0.16, 0.66, 0.6, 0.22]
root_b_edge_hidden_vertex_hidden_y: [0.04, 0.1, 0.48, 0.54]
root_b_edge_hidden_vertex_hidden_x_uv: [[root_b_edge_hidden_vertex_hidden_x.0, root_b_edge_hidden_vertex_hidden_x.3], [root_b_edge_hidden_vertex_hidden_x.1, root_b_edge_hidden_vertex_hidden_x.2]]
root_b_edge_hidden_vertex_hidden_y_uv: [[root_b_edge_hidden_vertex_hidden_y.0, root_b_edge_hidden_vertex_hidden_y.3], [root_b_edge_hidden_vertex_hidden_y.1, root_b_edge_hidden_vertex_hidden_y.2]]
root_b_edge_hidden_vertex_hidden: root_b_edge_hidden.add(
  x_uv: root_b_edge_hidden_vertex_hidden_x_uv,
  y_uv: root_b_edge_hidden_vertex_hidden_y_uv,
  z: 0,
  face_color: [0.16, 0.74, 0.34, 0.46],
  edge_color: [0.2, 1, 0.7, 1],
  vertex_color: [1, 0.25, 0.78, 0],
  origin: [0.41, 0.29, 0],
  vertex_size: 4,
  edge_width: 2
)

root_c_x: [-1, 1, 1, -1]
root_c_y: [-1, -1, 1, 1]
root_c_x_uv: [[root_c_x.0, root_c_x.3], [root_c_x.1, root_c_x.2]]
root_c_y_uv: [[root_c_y.0, root_c_y.3], [root_c_y.1, root_c_y.2]]
root_c: panel.add(
  x_uv: root_c_x_uv,
  y_uv: root_c_y_uv,
  z: 0,
  face_color: [0.22, 0.54, 0.96, 0.46],
  edge_color: [0.12, 0.95, 0.95, 1],
  vertex_color: [1, 0.82, 0.2, 1],
  bounds: [680, 70, 220, 200],
  origin: [0, 0, 0],
  vertex_size: 4,
  edge_width: 2
)

root_c_vertex_hidden_x: [-0.58, 0.58, 0.5, -0.5]
root_c_vertex_hidden_y: [-0.52, -0.42, 0.48, 0.56]
root_c_vertex_hidden_x_uv: [[root_c_vertex_hidden_x.0, root_c_vertex_hidden_x.3], [root_c_vertex_hidden_x.1, root_c_vertex_hidden_x.2]]
root_c_vertex_hidden_y_uv: [[root_c_vertex_hidden_y.0, root_c_vertex_hidden_y.3], [root_c_vertex_hidden_y.1, root_c_vertex_hidden_y.2]]
root_c_vertex_hidden: root_c.add(
  x_uv: root_c_vertex_hidden_x_uv,
  y_uv: root_c_vertex_hidden_y_uv,
  z: 0,
  face_color: [0.22, 0.54, 0.96, 0.46],
  edge_color: [0.12, 0.95, 0.95, 1],
  vertex_color: [1, 0.82, 0.2, 0],
  vertex_size: 4,
  edge_width: 2
)

root_c_vertex_hidden_face_hidden_x: [-0.72, -0.24, -0.3, -0.66]
root_c_vertex_hidden_face_hidden_y: [-0.56, -0.5, -0.12, -0.06]
root_c_vertex_hidden_face_hidden_x_uv: [[root_c_vertex_hidden_face_hidden_x.0, root_c_vertex_hidden_face_hidden_x.3], [root_c_vertex_hidden_face_hidden_x.1, root_c_vertex_hidden_face_hidden_x.2]]
root_c_vertex_hidden_face_hidden_y_uv: [[root_c_vertex_hidden_face_hidden_y.0, root_c_vertex_hidden_face_hidden_y.3], [root_c_vertex_hidden_face_hidden_y.1, root_c_vertex_hidden_face_hidden_y.2]]
root_c_vertex_hidden_face_hidden: root_c_vertex_hidden.add(
  x_uv: root_c_vertex_hidden_face_hidden_x_uv,
  y_uv: root_c_vertex_hidden_face_hidden_y_uv,
  z: 0,
  face_color: [0.22, 0.54, 0.96, 0],
  edge_color: [0.12, 0.95, 0.95, 1],
  vertex_color: [1, 0.82, 0.2, 1],
  vertex_size: 4,
  edge_width: 2
)

root_c_vertex_hidden_edge_hidden_x: [0.16, 0.66, 0.6, 0.22]
root_c_vertex_hidden_edge_hidden_y: [0.04, 0.1, 0.48, 0.54]
root_c_vertex_hidden_edge_hidden_x_uv: [[root_c_vertex_hidden_edge_hidden_x.0, root_c_vertex_hidden_edge_hidden_x.3], [root_c_vertex_hidden_edge_hidden_x.1, root_c_vertex_hidden_edge_hidden_x.2]]
root_c_vertex_hidden_edge_hidden_y_uv: [[root_c_vertex_hidden_edge_hidden_y.0, root_c_vertex_hidden_edge_hidden_y.3], [root_c_vertex_hidden_edge_hidden_y.1, root_c_vertex_hidden_edge_hidden_y.2]]
root_c_vertex_hidden_edge_hidden: root_c_vertex_hidden.add(
  x_uv: root_c_vertex_hidden_edge_hidden_x_uv,
  y_uv: root_c_vertex_hidden_edge_hidden_y_uv,
  z: 0,
  face_color: [0.22, 0.54, 0.96, 0.46],
  edge_color: [0.12, 0.95, 0.95, 0],
  vertex_color: [1, 0.82, 0.2, 1],
  origin: [0.41, 0.29, 0],
  vertex_size: 4,
  edge_width: 2
)

drag_active: false
drag_hover: (object_id: -1, kind: -1, face_id: -1, edge_id: -1, vertex_id: -1, frame_id: -1)
drag_hover_valid: false
drag_origo: [0, 0]
drag_start_vertex_angle: 0
drag_start_vertex_radius: 1
drag_start_edge_normal: [0, 0]
drag_start_edge_ref: 1

top_panel_frame: panel

set_drag_from_hover(target_hover, e):
  drag_hover: target_hover
  drag_hover_valid: false
  target: top_panel_frame.get(target_hover)
  target?
    target_hover.kind?>
      ui.HOVER_VERTEX =>
        drag_hover: target_hover
        drag_hover_valid: true
        drag_active: true
        drag_origo: target.world_inner_point(target.origin)
        drag_vertex: target.world_point(target_hover.vertex_id)
        drag_start_vertex_angle: math.atan2(drag_vertex.1 - drag_origo.1, drag_vertex.0 - drag_origo.0)
        drag_start_vertex_radius: math.sqrt((drag_vertex.0 - drag_origo.0)^2 + (drag_vertex.1 - drag_origo.1)^2)
      ui.HOVER_EDGE =>
        drag_hover: target_hover
        drag_hover_valid: true
        drag_active: true
        edge_indices: target.edges[target_hover.edge_id]
        edge_a: target._parent_point_from_inner([target.x[edge_indices.0], target.y[edge_indices.0], target.z[edge_indices.0]])
        edge_b: target._parent_point_from_inner([target.x[edge_indices.1], target.y[edge_indices.1], target.z[edge_indices.1]])
        edge_ex: edge_b.0 - edge_a.0
        edge_ey: edge_b.1 - edge_a.1
        edge_len: math.sqrt(edge_ex^2 + edge_ey^2)
        drag_origo: target.world_inner_point(target.origin)
        drag_start_edge_normal: [-edge_ey / edge_len, edge_ex / edge_len]
        edge_ref: (e.local_cursor.0 - drag_origo.0) * drag_start_edge_normal.0 + (e.local_cursor.1 - drag_origo.1) * drag_start_edge_normal.1
        drag_start_edge_ref: edge_ref
      ui.HOVER_FACE =>
        drag_hover: target_hover
        drag_hover_valid: true
        drag_active: true
      @|
  @|

drag_target(target_hover, e, mods):
  target: top_panel_frame.get(target_hover)
  target?
    mods.ctrl?
      target_hover.kind?>
        ui.HOVER_VERTEX =>
          target.move_vertex(vertex: target_hover.vertex_id, local_cursor: e.local_cursor, local_trans: e.local_trans)
        ui.HOVER_EDGE =>
          target.translate_edge(edge: target_hover.edge_id, local_trans: e.local_trans)
      @|
    target_hover.kind?>
      ui.HOVER_VERTEX =>
        target_vec: [e.local_cursor.0 - drag_origo.0, e.local_cursor.1 - drag_origo.1]
        target_angle: math.atan2(target_vec.1, target_vec.0)
        target_radius: math.sqrt(target_vec.0^2 + target_vec.1^2)
        target.rotate_scale_at_vertex(
          vertex: target_hover.vertex_id,
          origo: drag_origo,
          angle: target_angle - drag_start_vertex_angle,
          scale: target_radius / drag_start_vertex_radius
        )
      ui.HOVER_EDGE =>
        edge_scale: ((e.local_cursor.0 - drag_origo.0) * drag_start_edge_normal.0 + (e.local_cursor.1 - drag_origo.1) * drag_start_edge_normal.1) / drag_start_edge_ref
        target.scale_edge(edge: target_hover.edge_id, origo: drag_origo, scale: edge_scale)
      ui.HOVER_FACE =>
        target.translate(trans: e.local_trans)

drag(e):
  mods: ui.keyboard.modifiers
  drag_hover_valid?
    drag_target(drag_hover, e, mods)

:: "vkf topology ready"

(e: events.get())??>
  ui.MOUSE_DOWN =>
    ui.cursor.set_mode("closed_hand")
    drag_active: false
    set_drag_from_hover(e.hover, e)
  ui.MOUSE_MOVE =>
    ui.cursor.set_mode("open_hand")
  ui.MOUSE_DRAG =>
    drag(e)
  ui.MOUSE_UP =>
    drag_active: false
    ui.cursor.set_mode("open_hand")
  t.sleep(0.016)
