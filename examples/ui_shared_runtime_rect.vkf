  edge_color: [0.98, 0.72, 0.2, 0],
  vertex_color: [1, 0.2, 0.72, 1],
  origin: [-0.48, -0.31, 0],
  vertex_size: 4,
  edge_width: 2
)

root_a_face_hidden_vertex_hidden_x: [0.16, 0.66, 0.6, 0.22]
root_a_face_hidden_vertex_hidden_y: [0.04, 0.1, 0.48, 0.54]
root_a_face_hidden_vertex_hidden_x_uv: [[root_a_face_hidden_vertex_hidden_x.0, root_a_face_hidden_vertex_hidden_x.3], [root_a_face_hidden_vertex_hidden_x.1, root_a_face_hidden_vertex_hidden_x.2]]
root_a_face_hidden_vertex_hidden_y_uv: [[root_a_face_hidden_vertex_hidden_y.0, root_a_face_hidden_vertex_hidden_y.3], [root_a_face_hidden_vertex_hidden_y.1, root_a_face_hidden_vertex_hidden_y.2]]
root_a_face_hidden_vertex_hidden: root_a_face_hidden.add(
  x_uv: root_a_face_hidden_vertex_hidden_x_uv,
  y_uv: root_a_face_hidden_vertex_hidden_y_uv,
  z: 0,
  face_color: [0.9, 0.24, 0.16, 0.46],
  edge_color: [0.98, 0.72, 0.2, 1],
  vertex_color: [1, 0.2, 0.72, 0],
  origin: [0.41, 0.29, 0],
  vertex_size: 4,
  edge_width: 2
