# VKF-driven topology hierarchy transform interaction.
# Geometry coordinates are normalized: lower-left (-1,-1), upper-right (1,1).

ui: .ui
t: .time
events: ui.events
d: ui.display

panel: d.frame(
  title: "VKF topology transforms",
  draggable: true,
  closable: true,
  resizable: true,
  dockable: true,
  dock_loc: "bl",
  alpha: 0.96,
  master: true
)

d.add_frame(panel, [0, 0, d.width, d.height])

root_a: panel.add(
  x: [-1, 1, 1, -1],
  y: [-1, -1, 1, 1],
  face_color: [0.9, 0.24, 0.16, 0.46],
  edge_color: [0.98, 0.72, 0.2, 1],
  vertex_color: [1, 0.2, 0.72, 1],
  bounds: [80, 70, 220, 200],
  origin: [0, 0, 0],
  vertex_radius: 4,
  edge_radius: 2
)
root_a.add_vertices([0, 1, 2, 3])
root_a.add_edges([[0, 1], [1, 2], [2, 3], [3, 0]])
root_a.add_faces([[0, 1, 2, 3]])

root_a_face_hidden: root_a.add(
  x: [-0.58, 0.58, 0.5, -0.5],
  y: [-0.52, -0.42, 0.48, 0.56],
  face_color: [0.9, 0.24, 0.16, 0],
  edge_color: [0.98, 0.72, 0.2, 1],
  vertex_color: [1, 0.2, 0.72, 1],
  origin: [0, 0, 0],
  vertex_radius: 4,
  edge_radius: 2
)
root_a_face_hidden.add_vertices([0, 1, 2, 3])
root_a_face_hidden.add_edges([[0, 1], [1, 2], [2, 3], [3, 0]])
root_a_face_hidden.add_faces([[0, 1, 2, 3]])

root_a_face_hidden_edge_hidden: root_a_face_hidden.add(
  x: [-0.72, -0.24, -0.3, -0.66],
  y: [-0.56, -0.5, -0.12, -0.06],
  face_color: [0.9, 0.24, 0.16, 0.46],
  edge_color: [0.98, 0.72, 0.2, 0],
  vertex_color: [1, 0.2, 0.72, 1],
  origin: [-0.48, -0.31, 0],
  vertex_radius: 4,
  edge_radius: 2
)
root_a_face_hidden_edge_hidden.add_vertices([0, 1, 2, 3])
root_a_face_hidden_edge_hidden.add_edges([[0, 1], [1, 2], [2, 3], [3, 0]])
root_a_face_hidden_edge_hidden.add_faces([[0, 1, 2, 3]])

root_a_face_hidden_vertex_hidden: root_a_face_hidden.add(
  x: [0.16, 0.66, 0.6, 0.22],
  y: [0.04, 0.1, 0.48, 0.54],
  face_color: [0.9, 0.24, 0.16, 0.46],
  edge_color: [0.98, 0.72, 0.2, 1],
  vertex_color: [1, 0.2, 0.72, 0],
  origin: [0.41, 0.29, 0],
  vertex_radius: 4,
  edge_radius: 2
)
root_a_face_hidden_vertex_hidden.add_vertices([0, 1, 2, 3])
root_a_face_hidden_vertex_hidden.add_edges([[0, 1], [1, 2], [2, 3], [3, 0]])
root_a_face_hidden_vertex_hidden.add_faces([[0, 1, 2, 3]])

