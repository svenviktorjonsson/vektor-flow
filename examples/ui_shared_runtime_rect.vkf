# VKF-driven topology hierarchy transform interaction.
# Geometry coordinates are normalized: lower-left (-1,-1), upper-right (1,1).

ui: .ui
t: .time
events: ui.events
d: ui.display
math: .math

panel: d.frame(
  title: "VKF topology transforms",
  draggable: true,
  closable: true,
  resizable: true,
  dockable: true,
  dock_loc: "bl",
  alpha: 0.96,
  master: true
)

d.add_frame(panel, [0, 0, d.width, d.height])

root_a_x: [-1, 1, 1, -1]
root_a_y: [-1, -1, 1, 1]
root_a_x_uv: [[root_a_x.0, root_a_x.3], [root_a_x.1, root_a_x.2]]
root_a_y_uv: [[root_a_y.0, root_a_y.3], [root_a_y.1, root_a_y.2]]
root_a: panel.add(
  x_uv: root_a_x_uv,
  y_uv: root_a_y_uv,
  z: 0,
  face_color: [0.9, 0.24, 0.16, 0.46],
  edge_color: [0.98, 0.72, 0.2, 1],
  vertex_color: [1, 0.2, 0.72, 1],
  bounds: [80, 70, 220, 200],
  origin: [0, 0, 0],
  vertex_size: 4,
  edge_width: 2
)

root_a_face_hidden_x: [-0.58, 0.58, 0.5, -0.58]
root_a_face_hidden_y: [-0.52, -0.42, 0.48, 0.56]
root_a_face_hidden_x_uv: [[root_a_face_hidden_x.0, root_a_face_hidden_x.3], [root_a_face_hidden_x.1, root_a_face_hidden_x.2]]
root_a_face_hidden_y_uv: [[root_a_face_hidden_y.0, root_a_face_hidden_y.3], [root_a_face_hidden_y.1, root_a_face_hidden_y.2]]
root_a_face_hidden: root_a.add(
  x_uv: root_a_face_hidden_x_uv,
  y_uv: root_a_face_hidden_y_uv,
  z: 0,
  face_color: [0.9, 0.24, 0.16, 0],
  edge_color: [0.98, 0.72, 0.2, 1],
  vertex_color: [1, 0.2, 0.72, 1],
  vertex_size: 4,
  edge_width: 2
)

root_a_face_hidden_edge_hidden_x: [-0.72, -0.24, -0.3, -0.66]
root_a_face_hidden_edge_hidden_y: [-0.56, -0.5, -0.12, -0.06]
root_a_face_hidden_edge_hidden_x_uv: [[root_a_face_hidden_edge_hidden_x.0, root_a_face_hidden_edge_hidden_x.3], [root_a_face_hidden_edge_hidden_x.1, root_a_face_hidden_edge_hidden_x.2]]
root_a_face_hidden_edge_hidden_y_uv: [[root_a_face_hidden_edge_hidden_y.0, root_a_face_hidden_edge_hidden_y.3], [root_a_face_hidden_edge_hidden_y.1, root_a_face_hidden_edge_hidden_y.2]]
root_a_face_hidden_edge_hidden: root_a_face_hidden.add(
  x_uv: root_a_face_hidden_edge_hidden_x_uv,
  y_uv: root_a_face_hidden_edge_hidden_y_uv,
