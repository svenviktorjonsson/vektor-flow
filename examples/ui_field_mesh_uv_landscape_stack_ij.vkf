# Stacked UV landscapes using grouping dims i and j.
# Connectivity from u,v only; i,j are grouping axes.
# Both layers use alpha=0.4 and different colors.

ui:.ui

d: ui.display
f: d.frame(
    title: "field_mesh stacked landscape (i,j groups)",
    dock_loc: "bl",
    resizable: true,
    alpha: 0.6
)

d.add_frame(f, (0.06, 0.06, 0.88, 0.88))

