ui:.ui

screen: ui.display
w: ui.widgets

run_tag: "native-scene-probe ready"
prompt: "focus left pane, then move / click / type"

input_frame: ui.Frame()
log_frame: ui.Frame()

screen.add_frame(input_frame, (0.06, 0.08, 0.38, 0.78))
screen.add_frame(
    log_frame,
    (0.48, 0.05, 0.46, 0.86),
    body: [w.text_area("log", text: run_tag & "\n" & prompt & "\n", rows: 24, readonly: true)]
)
screen.render()
