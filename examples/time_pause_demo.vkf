# std `time` only тАФ `::` prints; `sleep` does not return anything useful, so call it without `::`.
# Run:  vkf examples/time_pause_demo.vkf
# Last pause 60s (Ctrl+C to exit early if you like.)

:.time

:: "--- time demo тАФ pauses only, minimal prints ---"
:: "0.4s"
sleep(0.4)
:: "1.5s"
sleep(1.5)
:: "3s (read the lines above)"
sleep(3.0)
:: "60s final pause (then one line: done.)"
sleep(60)
:: "done."
