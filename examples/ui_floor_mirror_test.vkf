            color_b: [0.90, 0.92, 0.96, 1.0]
        )
    ),
    lights: [
        (
            id: "real_light",
            kind: "point",
            motion: "orbit",
            target: [0.0, 0.0, 1.0],
            radius: 4.6,
            height: 4.8,
            theta: -0.62,
            angular_velocity: 0.9,
            model: "blinn_phong",
            color: [1.0, 0.93, 0.78, 1.0],
            intensity: 24.0,
            range: 24.0,
            casts_shadow: true,
            source_radius: 0.18,
            spread: 1.0
        ),
        (
            id: "virtual_light",
            kind: "projected",
            reflect_of_light_id: "real_light",
            reflect_mirror_mesh_id: "mirror_face",
            model: "blinn_phong",
            color: [1.0, 0.93, 0.78, 1.0],
            intensity: 120.0,
            range: 24.0,
            casts_shadow: true,
