    rect: [0.10, 0.08, 0.76, 0.76],
    aspect: "equal",
    show_light_markers: true,
    light_marker_size: 0.18,
    camera: (
        pos: [0.0, -4.2, 3.5],
        target: [0.0, 0.0, 0.0],
        orbit_step_deg: 5.0,
        fov: 34.0,
        up: [0.0, 0.0, 1.0]
    ),
    surfaces: [
        (
            id: "mirror_face",
            center: [0.0, 0.0, 1.0],
            size: [2.0, 2.0],
            rotation: [-90.0, 0.0, 0.0],
            color: [0.24, 0.26, 0.30, 1.0],
            no_backface_specular: true,
            surface_system: (
                kind: "screen",
                reverse_facing: true,
                scale: [1.0, 1.0],
                camera: (
                    fov: 34.0,
                    up: [0.0, 0.0, 1.0],
                    mirror_of: (
                        frame_id: "main_mirror_frame",
                        mesh_id: "mirror_face",
                        reflect_eye_only: true,
                        lock_aperture_camera: true,
                        controls_enabled: false
                    )
                )
            )
        )
    ],
    plane: (
        center: [0.0, 0.0],
        size: 8.0,
        z: 0.0,
        color: [1.0, 1.0, 1.0, 1.0],
        texture: (
            kind: "checker",
            scale: [1.0, 1.0],
