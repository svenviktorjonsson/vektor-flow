# UV saddle surface verification example.
# Dense, slightly stronger curvature: z = 0.40*(x^2 - y^2), z-up

ui:.ui

d: ui.display
f: d.frame(
    title: "field_mesh uv saddle (lower angle)",
    dock_loc: "bl",
    resizable: true
)

d.add_frame(f, (0.1, 0.08, 0.76, 0.84))

