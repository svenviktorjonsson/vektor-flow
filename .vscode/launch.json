{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "vkf: run current file",
      "type": "python",
      "request": "launch",
      "module": "vektorflow.cli",
      "args": ["${file}"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}
